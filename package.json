{
  "name": "likec4",
  "version": "0.1.0",
  "description": "Obsidian plugin for rendering LikeC4 architecture diagrams inline",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs --production",
    "deploy": "node esbuild.config.mjs --production && cp main.js manifest.json styles.css \"$OBSIDIAN_VAULT/.obsidian/plugins/likec4/\""
  },
  "dependencies": {
    "@likec4/core": "^1.52.0",
    "@likec4/diagram": "^1.52.0",
    "@likec4/language-services": "^1.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.7.0"
  }
}
